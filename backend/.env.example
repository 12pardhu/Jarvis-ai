## LLM (Ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT_S=15

## Conversation context
JARVIS_CONTEXT_TURNS=8

## Translation (Phase 4)
# Options: noop | libretranslate
JARVIS_TRANSLATE_PROVIDER=noop
JARVIS_TRANSLATE_URL=http://localhost:5000/translate
# JARVIS_TRANSLATE_API_KEY=
JARVIS_TRANSLATE_TIMEOUT_S=5

## Automation safety
JARVIS_ALLOW_POWER_COMMANDS=false

## Security (Phase 6)
# When true, frontend should login before using chat, and you should protect requests with JARVIS_API_TOKEN.
JARVIS_REQUIRE_AUTH=false
# Optional header token protection (send as X-API-Token)
# JARVIS_API_TOKEN=change-me
# Voice + PIN secrets (bcrypt hashes). Generate with:
# python3 -c "import bcrypt; print(bcrypt.hashpw(b'my phrase', bcrypt.gensalt()).decode())"
# python3 -c "import bcrypt; print(bcrypt.hashpw(b'1234', bcrypt.gensalt()).decode())"
# JARVIS_VOICE_PASSPHRASE_HASH=
# JARVIS_PIN_HASH=
